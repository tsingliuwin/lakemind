# MaxCompute spike connection parameters.
#
# USAGE:
#   1. Copy this file to `odps-spike.env` (same folder):  cp odps-spike.env.example odps-spike.env
#   2. Fill in real values below.
#   3. `odps-spike.env` is gitignored — it will never be committed.
#
# SECURITY: Do NOT paste these values (especially the Secret) into chat.
#           The agent reads `odps-spike.env` from disk only.

# --- Endpoint (MaxCompute API) ---
# Classic network:        http://service.odps.aliyun.com/api
# Region (cn-hangzhou):    http://service.cn-hangzhou.maxcompute.aliyun.com/api
# New public endpoint:    https://maxcompute.cn-hangzhou.aliyuncs.com
ODPS_ENDPOINT=http://service.cn-hangzhou.maxcompute.aliyun.com/api

# --- Tunnel endpoint (optional) ---
# odps-jdbc usually auto-resolves this from ODPS_ENDPOINT.
# Set it only if the driver fails to resolve it for your region.
# Example: http://dt.cn-hangzhou.maxcompute.aliyun.com
ODPS_TUNNEL_ENDPOINT=

# --- Project & test tables ---
ODPS_PROJECT=
# A table with many column types (BIGINT/STRING/DATETIME/DECIMAL/ARRAY/STRUCT/MAP)
# and a known row count — used for the type-mapping + correctness checks.
ODPS_TABLE=
# Optional larger table (e.g. 1M–10M rows) for the throughput test.
ODPS_LARGE_TABLE=

# --- Credentials (SECRETS — do not commit, do not paste in chat) ---
ODPS_ACCESS_KEY_ID=
ODPS_ACCESS_KEY_SECRET=

# Optional region tag (for logs / endpoint sanity)
ODPS_REGION=cn-hangzhou
